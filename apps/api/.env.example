# Skopiuj do .env w tym katalogu (apps/api/.env). Nie commituj .env.
# Opis: docs/runbook.md

# Supabase (ten sam projekt co w NEXT_PUBLIC_* na frontendzie)
# SUPABASE_URL=
# SUPABASE_KEY=
# SUPABASE_JWT_SECRET=

# ENCRYPTION_KEY=

# Opcjonalnie: Google OAuth, OpenRouter
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=
# CORS_ORIGINS=
