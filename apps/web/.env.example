# Skopiuj do .env.local i uzupełnij. Nie commituj .env.local.
# Wartości: Supabase Dashboard → Project Settings → API

# Wymagane (frontend: logowanie, sesja)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Opcjonalnie: zmienne serwerowe (API Routes) możesz dodać tutaj lub w .env w root
# SUPABASE_URL=...
# SUPABASE_KEY=...
# SUPABASE_JWT_SECRET=...
# ENCRYPTION_KEY=...
