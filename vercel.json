{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "pnpm --filter @repo/shared build && pnpm --filter web build",
  "installCommand": "pnpm install",
  "outputDirectory": "apps/web/.next",
  "functions": {
    "api/python-api.py": {
      "maxDuration": 30
    }
  }
}
